---
import { getCollection } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import DetailSection from '@/components/DetailSection.astro';
import DescriptionList from '@/components/DescriptionList.astro';
import DetailImage from '@/components/DetailImage.astro';
import Scroll from '@/components/Scroll.astro';
import Stalker from '@/components/Stalker';
import NextWork from '@/components/NextWork.astro';
import DetailInfo from '@/components/DetailInfo.astro';
import BackToList from '@/components/BackToList.astro';
import updatePath from '@/libs/updatePath';
import works from '@/data/works';

export async function getStaticPaths() {
  const entries = await getCollection('works');
  return entries.map(entry => ({ params: { slug: entry.slug } }));
}

const { slug } = Astro.params;
const entries = await getCollection('works');
const entry = entries.find(e => e.slug === slug)!;
const { Content } = await entry.render();

// works.ts から DetailInfo・NextWork 用のデータを取得
const work = works.find(w => w.slug === slug);
const workIndex = works.findIndex(w => w.slug === slug);
const nextWork = works[workIndex + 1] || works[0];

const { imageCount, url, description } = entry.data;
// 詳細画像のインデックス配列（2.jpg〜N.jpg）
const imageIndices = Array.from({ length: imageCount }, (_, i) => i + 2);
---

<Layout title={entry.data.title} isContainer={false}>
  <Scroll />

  <section
    id="horizontal-scroll"
    class="container w-full pt-[var(--header-height)] md:h-screen md:px-20 md:pt-0"
  >
    <div
      id="horizontal-scroll-container"
      class="w-full md:flex md:h-full md:w-max md:flex-nowrap md:items-center md:whitespace-nowrap md:[&>*]:h-full"
    >
      <DetailInfo work={work} />

      <DetailSection title="(Overview)">
        <div class="flex flex-col gap-4 md:text-lg">
          <Content />
          {url && (
            <p class="mt-12 flex gap-4 font-serif-en md:gap-12">
              <span class="text-gray">URL</span>
              <a
                class="underline"
                href={url}
                target="_blank"
                rel="noopener noreferrer"
              >{url}</a>
            </p>
          )}
        </div>
      </DetailSection>

      <picture class="ts-horizontal-scroll-item">
        <img
          src={updatePath(`/detail/${slug}/1.jpg`)}
          alt=""
          class="ts-image-white-in md:h-full"
        />
      </picture>

      <DetailSection title="(Description)" contentWidth="wide">
        {description.map(item => (
          <DescriptionList>
            <span slot="title">{item.title}</span>
            <span slot="description" set:html={item.content.replace(/\n/g, '<br />')} />
          </DescriptionList>
        ))}
      </DetailSection>

      {imageIndices.length > 0 && (
        <div class="ts-horizontal-scroll-item">
          <div class="h-full px-5 md:px-0 md:py-[7.5rem]">
            <DetailImage>
              {imageIndices.map(i => (
                <li>
                  <picture>
                    <img
                      src={updatePath(`/detail/${slug}/${i}.jpg`)}
                      alt=""
                      class="ts-image-white-in"
                    />
                  </picture>
                </li>
              ))}
            </DetailImage>
          </div>
        </div>
      )}

      <BackToList />
      <NextWork work={nextWork} />
    </div>
  </section>

  <Stalker client:only="react" />
</Layout>

<script>
  import horizontalScroll from '@/libs/horizontalScroll';
  import imageWhiteIn from '@/libs/imageWhiteIn';
  horizontalScroll();
  imageWhiteIn();
</script>
